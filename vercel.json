{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json", 
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "server/api-test.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api-test",
      "dest": "/server/api-test.ts"
    },
    { 
      "src": "/api/(.*)",
      "dest": "/server/index.ts"
    },
    {
      "src": "/(assets|images|fonts|js|css)(.*)",
      "dest": "/client/dist/$1$2"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/index.html"
    }
  ]
}
