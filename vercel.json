{
  "framework": null,
  "version": 2,
  "functions": {
    "api/*.js": {
      "memory": 1024
    }
  },
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
