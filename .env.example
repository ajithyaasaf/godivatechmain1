# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Optional Firebase Configuration
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain # Default: {project_id}.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket # Default: {project_id}.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# Session Configuration (for traditional auth)
SESSION_SECRET=your_session_secret

# Other Environment Variables
NODE_ENV=development